<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/dark_card"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Avatar -->
        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:gravity="center"
            android:textColor="@color/text_white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_avtar"
            android:layout_marginEnd="12dp" />

        <!-- Player Name -->
        <TextView
            android:id="@+id/tvPlayerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Player Name"
            android:textColor="@color/text_white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Present Button -->
        <TextView
            android:id="@+id/btnPresent"
            android:layout_width="40dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="P"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/status_green"
            android:background="@drawable/bg_btn_present_unsel"
            android:layout_marginEnd="6dp" />

        <!-- Absent Button -->
        <TextView
            android:id="@+id/btnAbsent"
            android:layout_width="40dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="A"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/status_red"
            android:background="@drawable/bg_btn_absent_unsel" />


    </LinearLayout>
</androidx.cardview.widget.CardView>