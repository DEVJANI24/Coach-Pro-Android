<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/dark_card"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

    <!-- Player Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:gravity="center"
            android:textColor="@color/text_white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_avtar"
            android:layout_marginEnd="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPlayerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Player Name"
                android:textColor="@color/text_white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPlayerInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Class • Position"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Edit Button -->
        <TextView
            android:id="@+id/btnEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏️"
            android:textSize="16sp"
            android:padding="4dp" />
    </LinearLayout>

    <!-- Stats Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <!-- Points -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/dark_card2"
            android:padding="8dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:id="@+id/tvPoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/accent_orange"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Points"
                android:textColor="@color/text_muted"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- Assists -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/dark_card2"
            android:padding="8dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:id="@+id/tvAssists"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/accent_orange"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assists"
                android:textColor="@color/text_muted"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- Rebounds -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/dark_card2"
            android:padding="8dp"
            android:layout_marginStart="4dp">

            <TextView
                android:id="@+id/tvRebounds"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/accent_orange"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rebounds"
                android:textColor="@color/text_muted"
                android:textSize="9sp" />
        </LinearLayout>
        </LinearLayout>

    <!-- Effort Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:text="Effort"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_progress_track"
            android:layout_marginEnd="8dp">

            <View
                android:id="@+id/effortBar"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_progress_fill" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvEffort"
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:text="0/5"
            android:textColor="@color/text_primary"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Defense Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:text="Defense"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_progress_track"
            android:layout_marginEnd="8dp">

            <View
                android:id="@+id/defenseBar"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_progress_fill" />

        </FrameLayout>

        <TextView
            android:id="@+id/tvDefense"
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:text="0/5"
            android:textColor="@color/text_primary"
            android:textSize="10sp" />
    </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>