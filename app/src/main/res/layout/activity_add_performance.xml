<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="←"
                android:textColor="@color/accent_orange"
                android:textSize="22sp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Performance"
                android:textColor="@color/text_white"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Session Info -->
        <TextView
            android:id="@+id/tvSessionName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Session: —"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

        <!-- Player Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPlayerName"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Player Name *"
            app:boxStrokeColor="@color/dark_card2"
            app:hintTextColor="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPlayerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:background="@color/dark_card"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Points -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPoints"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Points"
            android:layout_marginTop="12dp"
            app:boxStrokeColor="@color/dark_card2"
            app:hintTextColor="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPoints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:background="@color/dark_card"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Assists -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAssists"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Assists"
            android:layout_marginTop="12dp"
            app:boxStrokeColor="@color/dark_card2"
            app:hintTextColor="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAssists"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:background="@color/dark_card"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Rebounds -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilRebounds"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Rebounds"
            android:layout_marginTop="12dp"
            app:boxStrokeColor="@color/dark_card2"
            app:hintTextColor="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRebounds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:background="@color/dark_card"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Effort Rating -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Effort Rating"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <SeekBar
                android:id="@+id/seekEffort"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="5"
                android:progress="3"
                android:progressTint="@color/accent_orange"
                android:thumbTint="@color/accent_orange" />

            <TextView
                android:id="@+id/tvEffortVal"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="3/5"
                android:textColor="@color/accent_orange"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Defense Rating -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Defense Rating"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <SeekBar
                android:id="@+id/seekDefense"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="5"
                android:progress="3"
                android:progressTint="@color/accent_orange"
                android:thumbTint="@color/accent_orange" />

            <TextView
                android:id="@+id/tvDefenseVal"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="3/5"
                android:textColor="@color/accent_orange"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Error -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/status_red"
            android:textSize="12sp"
            android:layout_marginTop="6dp"
            android:visibility="gone" />

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp"
            android:text="Save Performance"
            android:textColor="@color/text_white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/accent_orange"
            android:stateListAnimator="@null" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/accent_orange"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>