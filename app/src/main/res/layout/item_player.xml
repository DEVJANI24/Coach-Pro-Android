<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/dark_card"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Avatar Circle -->
        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:textColor="@color/text_white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_avtar"
            android:layout_marginEnd="12dp" />

        <!-- Player Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPlayerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Player Name"
                android:textColor="@color/text_white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPlayerInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Class • Position"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Status Badge -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active"
            android:textSize="10sp"
            android:textColor="@color/status_green"
            android:background="@drawable/bg_badge_green"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>